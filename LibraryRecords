import { useEffect, useMemo, useState } from "react";

export default function LibraryManagementPage() {
  const [books, setBooks] = useState([]);
  const [selectedBook, setSelectedBook] = useState(null);
  const [error, setError] = useState("");

  // GitHub/Vite friendly configuration.
  // Create a `.env` file in the project root with:
  // VITE_GOOGLE_SHEET_URL=https://opensheet.elk.sh/<YOUR_SHEET_ID>/Sheet1
  //
  // Example:
  // VITE_GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/1aTIqzcDHyN1mIlCuBUQlNZEEA626KLfnsOPjb7NobF4/edit?usp=sharing
  const GOOGLE_SHEET_URL = import.meta.env.VITE_GOOGLE_SHEET_URL;

  const normalizeDate = (value) => {
    if (!value) return "";

    // Excel serial number support
    if (typeof value === "number") {
      const jsDate = new Date(Math.round((value - 25569) * 86400 * 1000));
      return jsDate.toISOString().split("T")[0];
    }

    const parsed = new Date(value);
    if (!Number.isNaN(parsed.getTime())) {
      return parsed.toISOString().split("T")[0];
    }

    return String(value);
  };

  useEffect(() => {
    const fetchBooks = async () => {
      if (!GOOGLE_SHEET_URL) {
        setError(
          "Missing VITE_GOOGLE_SHEET_URL. Add it in a .env file before deploying to GitHub Pages."
        );
        return;
      }
      try {
        setError("");

        const response = await fetch(GOOGLE_SHEET_URL);

        if (!response.ok) {
          throw new Error("Unable to fetch Google Sheet data");
        }

        const rows = await response.json();

        if (!Array.isArray(rows) || rows.length === 0) {
          setBooks([]);
          setSelectedBook(null);
          setError("No records found in the Google Sheet.");
          return;
        }

        const normalized = rows.map((row, index) => ({
          id: index + 1,
          title:
            row["Book title"] ||
            row["Book Title"] ||
            row["book title"] ||
            "Untitled Book",
          language:
            row["Book language"] ||
            row["Book Language"] ||
            row["book language"] ||
            "-",
          pendingWith:
            row["Pending with"] ||
            row["Pending With"] ||
            row["pending with"] ||
            "-",
          purchaseDate: normalizeDate(
            row["Purchase date"] ||
              row["Purchase Date"] ||
              row["purchase date"] ||
              ""
          ),
          latestyn: String(
            row["Latestyn flag"] ||
              row["LatestYN"] ||
              row["Latestyn"] ||
              row["latestyn flag"] ||
              ""
          )
            .trim()
            .toUpperCase(),
        }));

        setBooks(normalized);

        const firstLatest = normalized.find((book) => book.latestyn === "Y") || null;
        setSelectedBook(firstLatest);
      } catch (err) {
        console.error(err);
        setError(
          "Unable to load records from Google Sheet. Verify that the sheet is published and the URL is correct."
        );
      }
    };

    fetchBooks();
  }, []);

  const latestBuckets = useMemo(() => {
    return books.filter((book) => book.latestyn === "Y");
  }, [books]);

  const historyForSelected = useMemo(() => {
    if (!selectedBook) return [];

    return books
      .filter((book) => book.title === selectedBook.title)
      .sort((a, b) => {
        const dateA = new Date(a.purchaseDate).getTime();
        const dateB = new Date(b.purchaseDate).getTime();

        return dateA - dateB;
      });
  }, [books, selectedBook]);

  return (
    <div className="min-h-screen bg-slate-100 p-4 md:p-8">
      <div className="mx-auto max-w-7xl space-y-6">
        <div className="rounded-3xl bg-white p-6 shadow-lg">
          <div className="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <h1 className="text-3xl font-bold text-slate-800">Library Management</h1>
              <p className="mt-2 text-sm text-slate-500">
                Records are loaded automatically from your published Google Sheet containing Book title, Book language, Pending with, Purchase date and Latestyn flag.
              </p>
            </div>

            <div className="rounded-2xl bg-slate-50 px-5 py-4 text-sm text-slate-600">
              Data source: Google Sheet
              <div className="mt-1 font-mono text-xs text-slate-500 break-all">
                {GOOGLE_SHEET_URL || "Set VITE_GOOGLE_SHEET_URL in .env"}
              </div>
            </div>
          </div>

          {error && (
            <div className="mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
              {error}
            </div>
          )}
        </div>

        <div className="grid gap-6 lg:grid-cols-[1.1fr_1fr]">
          <div className="rounded-3xl bg-white p-6 shadow-lg">
            <div className="mb-4 flex items-center justify-between">
              <h2 className="text-xl font-semibold text-slate-800">
                Latest Books ({latestBuckets.length})
              </h2>
            </div>

            {latestBuckets.length === 0 ? (
              <div className="rounded-2xl border border-dashed border-slate-300 p-10 text-center text-slate-500">
                No latest records found in the Google Sheet.
              </div>
            ) : (
              <div className="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                {latestBuckets.map((book) => {
                  const isActive = selectedBook?.id === book.id;

                  return (
                    <button
                      key={book.id}
                      type="button"
                      onClick={() => setSelectedBook(book)}
                      className={`rounded-3xl border p-5 text-left transition-all duration-200 ${
                        isActive
                          ? "border-blue-600 bg-blue-50 shadow-xl"
                          : "border-slate-200 bg-white hover:-translate-y-1 hover:shadow-md"
                      }`}
                    >
                      <div className="flex items-start justify-between gap-3">
                        <div className="min-w-0 flex-1">
                          <h3 className="truncate text-lg font-bold text-slate-800">
                            {book.title}
                          </h3>
                          <p className="mt-1 text-sm text-slate-500">{book.language}</p>
                        </div>

                        <span className="rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-700">
                          Active
                        </span>
                      </div>

                      <div className="mt-4 space-y-2 text-sm text-slate-600">
                        <div>
                          <span className="font-medium">Pending with:</span> {book.pendingWith}
                        </div>
                        <div>
                          <span className="font-medium">Purchase date:</span> {book.purchaseDate}
                        </div>
                      </div>
                    </button>
                  );
                })}
              </div>
            )}
          </div>

          <div className="rounded-3xl bg-white p-6 shadow-lg">
            <h2 className="mb-4 text-xl font-semibold text-slate-800">Book History</h2>

            {!selectedBook ? (
              <div className="flex h-[320px] items-center justify-center rounded-2xl border border-dashed border-slate-300 text-center text-slate-500">
                Select a latest book bucket to view its purchase history.
              </div>
            ) : (
              <div>
                <div className="mb-5 rounded-2xl bg-slate-50 p-4">
                  <h3 className="text-lg font-bold text-slate-800">{selectedBook.title}</h3>
                  <p className="mt-1 text-sm text-slate-500">
                    Purchase history sorted by purchase date.
                  </p>
                </div>

                <div className="space-y-4">
                  {historyForSelected.map((entry) => {
                    const isLatest = entry.latestyn === "Y";

                    return (
                      <div
                        key={`${entry.id}-${entry.purchaseDate}-${entry.pendingWith}`}
                        className={`rounded-2xl border p-4 transition ${
                          isLatest
                            ? "border-red-500 bg-red-100"
                            : "border-slate-200 bg-slate-50"
                        }`}
                      >
                        <div className="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between">
                          <div>
                            <div className="text-sm font-medium text-slate-500">
                              Purchase Date
                            </div>
                            <div className="text-base font-semibold text-slate-800">
                              {entry.purchaseDate || "-"}
                            </div>
                          </div>

                          <div>
                            <div className="text-sm font-medium text-slate-500">
                              Pending With
                            </div>
                            <div className="text-base text-slate-800">
                              {entry.pendingWith}
                            </div>
                          </div>

                          <div>
                            <div className="text-sm font-medium text-slate-500">
                              Language
                            </div>
                            <div className="text-base text-slate-800">{entry.language}</div>
                          </div>

                          <div>
                            <span
                              className={`rounded-full px-3 py-1 text-xs font-semibold ${
                                isLatest
                                  ? "bg-red-600 text-white"
                                  : "bg-slate-200 text-slate-700"
                              }`}
                            >
                              {isLatest ? "Current Record" : "Historical"}
                            </span>
                          </div>
                        </div>
                      </div>
                    );
                  })}
                </div>
              </div>
            )}
          </div>
        </div>

        <div className="rounded-3xl bg-white p-6 shadow-lg">
          <h2 className="mb-3 text-lg font-semibold text-slate-800">Expected Excel Format</h2>

          <div className="overflow-x-auto rounded-2xl border border-slate-200">
            <table className="min-w-full text-sm">
              <thead className="bg-slate-100 text-left text-slate-700">
                <tr>
                  <th className="px-4 py-3">Book title</th>
                  <th className="px-4 py-3">Book language</th>
                  <th className="px-4 py-3">Pending with</th>
                  <th className="px-4 py-3">Purchase date</th>
                  <th className="px-4 py-3">Latestyn flag</th>
                </tr>
              </thead>
              <tbody>
                <tr className="border-t border-slate-200 bg-white">
                  <td className="px-4 py-3">Atomic Habits</td>
                  <td className="px-4 py-3">English</td>
                  <td className="px-4 py-3">Rahul</td>
                  <td className="px-4 py-3">2025-02-10</td>
                  <td className="px-4 py-3">Y</td>
                </tr>
                <tr className="border-t border-slate-200 bg-slate-50">
                  <td className="px-4 py-3">Atomic Habits</td>
                  <td className="px-4 py-3">English</td>
                  <td className="px-4 py-3">Priya</td>
                  <td className="px-4 py-3">2024-08-15</td>
                  <td className="px-4 py-3">N</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div className="mt-4 rounded-2xl bg-slate-50 p-4 text-sm text-slate-600">
            <p className="font-medium text-slate-700">GitHub Deployment Setup</p>
            <ol className="mt-2 list-decimal space-y-1 pl-5">
              <li>Create a Google Sheet with the required columns.</li>
              <li>Publish the sheet to the web.</li>
              <li>Install dependencies: <span className="font-mono">npm install</span></li>
              <li>Install GitHub Pages package: <span className="font-mono">npm install gh-pages --save-dev</span></li>
              <li>Create a <span className="font-mono">.env</span> file in the project root with:</li>
            </ol>
            <pre className="mt-3 overflow-x-auto rounded-xl bg-slate-900 p-3 text-xs text-slate-100">
{`VITE_GOOGLE_SHEET_URL=https://opensheet.elk.sh/YOUR_SHEET_ID/Sheet1`}
            </pre>
            <p className="mt-3">Add this to your <span className="font-mono">package.json</span>:</p>
            <pre className="mt-2 overflow-x-auto rounded-xl bg-slate-900 p-3 text-xs text-slate-100">
{`"homepage": "https://your-github-username.github.io/library-ui",
"scripts": {
  "dev": "vite",
  "build": "vite build",
  "deploy": "gh-pages -d dist"
}`}
            </pre>
            <p className="mt-3">Then deploy using:</p>
            <pre className="mt-2 overflow-x-auto rounded-xl bg-slate-900 p-3 text-xs text-slate-100">
{`npm run build
npm run deploy`}
            </pre>
          </div>
        </div>
      </div>
    </div>
  );
}
